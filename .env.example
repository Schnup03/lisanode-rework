# LisaNode Rework - Environment Configuration
# Copy this file to .env and fill in your values

# Required: OpenClaw Gateway Token
GATEWAY_TOKEN=your_gateway_token_here

# Optional: Gateway WebSocket URL
GATEWAY_URL=ws://127.0.0.1:18789

# Optional: Display name for this node
NODE_NAME=LisaNode-Windows

# Optional: IPC server port (default: 18888)
IPC_PORT=18888

# Optional: Enable debug logging
DEBUG=false
LOG_LEVEL=info
